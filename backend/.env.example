ENV=dev
LOG_LEVEL=INFO
SERVICE_NAME=devassist-backend

# LLM
LLM_PROVIDER=deepseek
LLM_API_KEY=sk-xxx
LLM_MODEL=deepseek-chat
LLM_BASE_URL=https://api.deepseek.com/v1

# Embedding
EMBEDDING_MODEL=embedding-3
EMBEDDING_API_KEY=sk-xxx
EMBEDDING_BASE_URL=https://api.openai.com/v1

# Chroma
CHROMA_HOST=chroma
CHROMA_PORT=8000
CHROMA_COLLECTION=devassist

# Database
DATABASE_URL=postgresql+asyncpg://devassist:devassist@db:5432/devassist

# Sandbox
SANDBOX_IMAGE=python:3.12-slim
SANDBOX_TIMEOUT=5
SANDBOX_MEMORY_LIMIT=256m

# vLLM (local serving)
VLLM_BASE_MODEL=Qwen/Qwen2.5-7B-Instruct
VLLM_API_KEY=devassist-local
VLLM_GPU_MEMORY_UTILIZATION=0.90
VLLM_TENSOR_PARALLEL_SIZE=1
VLLM_ENABLE_LORA=0
VLLM_LORA_NAME=devassist-lora
VLLM_LORA_PATH=/data/models/qwen2.5-7b-lora
VLLM_MAX_LORA_RANK=32
VLLM_ENABLE_CHUNKED_PREFILL=0
VLLM_MAX_MODEL_LEN=
VLLM_MAX_NUM_SEQS=
VLLM_MAX_NUM_BATCHED_TOKENS=
VLLM_KV_CACHE_DTYPE=
VLLM_QUANTIZATION=
VLLM_SWAP_SPACE=
VLLM_CPU_OFFLOAD_GB=
VLLM_DISABLE_LOG_STATS=0
VLLM_DISABLE_LOG_REQUESTS=0
VLLM_ENFORCE_EAGER=0
